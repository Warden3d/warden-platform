# ============================================================================
# WARDEN Platform — Environment Variables (example)
# ============================================================================
# Copy this file to .env.local and fill in your values.
# Without Supabase keys, the app falls back to local mock data.

# Supabase — Public (safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase — Service Role (server only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Site URL (used for metadata, OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
